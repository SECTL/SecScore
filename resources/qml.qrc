<!DOCTYPE RCC>
<RCC version="1.0">
    <qresource prefix="/qml">
        <file alias="App.qml">../qml/App.qml</file>
        <file alias="qmldir">../qml/qmldir</file>
        <file alias="pages/StudentsPage.qml">../qml/pages/StudentsPage.qml</file>
        <file alias="pages/EventsPage.qml">../qml/pages/EventsPage.qml</file>
        <file alias="pages/LeaderboardPage.qml">../qml/pages/LeaderboardPage.qml</file>
        <file alias="pages/SyncPage.qml">../qml/pages/SyncPage.qml</file>
    </qresource>
    <qresource prefix="/themes">
        <file alias="default.json">../themes/default.json</file>
        <file alias="dark.json">../themes/dark.json</file>
        <file alias="README.md">../themes/README.md</file>
    </qresource>
</RCC>
